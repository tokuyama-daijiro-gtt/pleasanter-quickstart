{
  "name": "devcontainer-test",
  "dockerComposeFile": [
    "../compose.yaml",
    "compose.devcontainer.yaml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/devcontainer-test",
  "initializeCommand": "bash ${localWorkspaceFolder}/.devcontainer/init-codedefiner.sh",
  "postStartCommand": "bash .devcontainer/show-pleasanter-url.sh",
  "runServices": [
    "devcontainer"
  ],
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "forwardPorts": [50001],
  "portsAttributes": {
    "50001": {
      "label": "Pleasanter"
    }
  }
}
