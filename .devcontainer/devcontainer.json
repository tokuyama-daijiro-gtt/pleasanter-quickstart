{
  "name": "pleasanter-quickstart",
  "dockerComposeFile": [
    "../compose.yaml",
    "compose.devcontainer.yaml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/pleasanter-quickstart",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "initializeCommand": "bash ${localWorkspaceFolder}/.devcontainer/initialize-pleasanter.sh",
  "postCreateCommand": "bash .devcontainer/setup-chrome-devtools-mcp.sh",
  "postAttachCommand": "bash .devcontainer/show-pleasanter-url.sh",
  "runServices": [
    "devcontainer",
    "ui"
  ],
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "forwardPorts": [50001, 3000],
  "portsAttributes": {
    "50001": {
      "label": "Pleasanter"
    },
    "3000": {
      "label": "Pleasanter Quickstart UI"
    }
  }
}
